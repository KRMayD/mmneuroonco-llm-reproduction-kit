# Copy this file outside the repository, fill in absolute paths, then run:
#   bash scripts/run_mmneuro_fixed_protocol_4encoders.sh /abs/path/mmneuro.env
#
# This configuration intentionally contains only machine-specific paths. All
# downstream training and evaluation hyperparameters are fixed in the runner.

REPO_ROOT="/abs/path/finegrainedVLM-vision-encoder-llm"
PYTHON_BIN="/abs/path/conda/envs/mmneuro/bin/python"

# Generated by scripts/prepare_mmneuro_official_vqa.py on this machine.
DATA_ROOT="/abs/path/mm_neuroonco_official"

# Local Hugging Face model snapshots.
BERT_ROOT="/abs/path/models/dmis-lab_biobert-v1.1"
LLM_ROOT="/abs/path/models/Qwen_Qwen3-0.6B"

# Vendored OpenCLIP source compatible with the four vision checkpoints.
OPENCLIP_SRC="/abs/path/finegrained-vlm-training/biomedclip_finetuning/open_clip/src"
MODEL_NAME="hf-hub:microsoft/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224"

# The only experimental variables: four frozen upstream vision encoders.
BASELINE_CKPT="/abs/path/checkpoints/openclip_model.pt"
CLIP_CKPT="/abs/path/checkpoints/clip_final_model.pt"
CLIPREFINE_CKPT="/abs/path/checkpoints/cliprefine_final_model.pt"
GMPO_CKPT="/abs/path/checkpoints/gmpo_sd_neg100_w00500511_epoch_3.pt"
GMPO_VARIANT="gmpo_sd_neg100"

# Four independent one-GPU jobs run concurrently in this order:
# baseline, CLIP, CLIPrefine, GMPO.
GPU_IDS="0,1,2,3"
RUN_ROOT="/abs/path/outputs/mmneuro_fixed_protocol"

# These identify a repeated run but do not alter the fixed protocol.
DOWNSTREAM_SEED="0"
RUN_STAMP=""
